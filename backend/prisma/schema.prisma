generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  country   String
  logoUrl   String?
  players   Player[]
  createdAt DateTime @default(now())

  @@map("teams")
}

model Player {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  dateOfBirth DateTime
  nationality String
  flagUrl     String?
  position    String  
  photoUrl    String?
  teamId      Int?
  team        Team?    @relation(fields: [teamId], references: [id])
  stats       PlayerStats[]
  height        String?
  preferredFoot String?
  marketValue   Int?
  shortlists  ShortlistPlayer[]
  createdAt   DateTime @default(now())

  @@index([nationality])
  @@index([position])
  @@index([teamId])
  @@map("players")
}

model Season {
  id      Int           @id @default(autoincrement())
  name    String        @unique // "2024", "2025", "2026"
  stats   PlayerStats[]

  @@map("seasons")
}

model PlayerStats {
  id               Int     @id @default(autoincrement())
  playerId         Int
  seasonId         Int
  player           Player  @relation(fields: [playerId], references: [id])
  season           Season  @relation(fields: [seasonId], references: [id])

  matchesPlayed    Int     @default(0)
  minutesPlayed    Int     @default(0)
  goals            Int     @default(0)
  assists          Int     @default(0)
  yellowCards      Int     @default(0)
  redCards         Int     @default(0)

  shotsOnTarget    Int     @default(0)
  successfulPasses Int     @default(0)
  passAccuracy     Float   @default(0)
  aerialDuelsWon   Int     @default(0)
  aerialDuelsTotal Int     @default(0)
  defensiveDuelsWon Int    @default(0)
  defensiveDuelsTotal Int  @default(0)
  xG               Float   @default(0) // Expected Goals
  xA               Float   @default(0) // Expected Assists
  recoveries       Int     @default(0)
  heatmapGrid      Json?

  @@unique([playerId, seasonId])
  @@index([playerId])
  @@map("player_stats")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  shortlist ShortlistPlayer[]
  createdAt DateTime @default(now())

  @@map("users")
}

model ShortlistPlayer {
  id        Int      @id @default(autoincrement())
  userId    Int
  playerId  Int
  user      User     @relation(fields: [userId], references: [id])
  player    Player   @relation(fields: [playerId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, playerId])
  @@map("shortlist_players")
}